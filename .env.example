# Base64-encoded Google service account JSON key
# Run: base64 -i your-key.json to generate this
GOOGLE_CREDENTIALS_B64=

# The calendar ID to create events in
# Use "primary" for the main calendar of the service account
# Or share your personal calendar with the service account and paste its ID here
GOOGLE_CALENDAR_ID=

# Optional: VAPI webhook secret for request validation
VAPI_SECRET=
